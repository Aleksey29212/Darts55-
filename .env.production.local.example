# =========================================================================
# DartBrig Pro - Пример конфигурации для Production (Timeweb)
# Инструкция: Скопируйте этот файл в .env.production.local и заполните его.
# =========================================================================

# 1. Firebase Config (из настроек проекта Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef...

# 2. Безопасность (Установите свой сложный пароль)
NEXT_PUBLIC_ADMIN_PASSWORD=your_super_secure_admin_password_here

# 3. Искусственный интеллект (Google AI Studio)
GEMINI_API_KEY=AIzaSy...

# 4. Настройки сервера
NODE_ENV=production
PORT=3000

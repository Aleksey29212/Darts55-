# Firebase Configuration
# Get these values from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
NEXT_PUBLIC_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"

# Admin and AI Configuration
NEXT_PUBLIC_ADMIN_PASSWORD="your_secret_admin_password_here"
GEMINI_API_KEY="your_google_gemini_api_key_here"

# GitHub Configuration for auto-deployment (optional)
# Used by the /admin/system page to trigger builds
GITHUB_TOKEN="ghp_..."
GITHUB_OWNER="your_github_username"
GITHUB_REPO="your_github_repo_name"
GITHUB_WORKFLOW_ID="deploy.yml"

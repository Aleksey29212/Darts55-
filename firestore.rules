
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Check if a document with the user's UID exists in the roles_admin collection.
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // WARNING: Write permissions are temporarily open for development.
    // TODO: Secure these rules before production by replacing 'if true' with 'if isAdmin()'.
    
    match /tournaments/{tournamentId} {
      allow get, list: if true;
      allow write: if true;
    }
    
    match /players/{playerId} {
      allow get, list: if true;
      allow write: if true;
    }
    
    match /partners/{partnerId} {
      allow get, list: if true;
      allow write: if true;
    }
    
    match /scoring_configurations/{configId} {
      allow get, list: if true;
      allow write: if true;
    }
    
    match /app_settings/{settingId} {
      allow get, list: if true;
      allow write: if true;
    }
    
    // Admin roles can only be read and managed by other admins.
    match /roles_admin/{userId} {
       allow read, write: if isAdmin();
    }

    // Visits collection is writable by anyone to log a visit, but only readable by admins.
    match /visits/{visitId} {
      allow create: if request.resource.data.keys().hasOnly(['timestamp']) && 
                   (request.resource.data.timestamp == request.time || request.resource.data.timestamp is timestamp);
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }
    
    match /sponsor_clicks/{clickId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }
  }
}
